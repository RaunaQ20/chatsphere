# Database
DATABASE_URL=postgresql+asyncpg://chatuser:chatpass@localhost:5432/chatdb
SYNC_DATABASE_URL=postgresql://chatuser:chatpass@localhost:5432/chatdb

# Redis
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your-super-secret-key-change-in-production-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=ChatSphere
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Stripe (for subscription)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_pro_price_id

# File uploads
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
